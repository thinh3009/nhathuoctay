# ──────────────────────────────────────────────────────────────────────────
# BẮT BUỘC cho app chạy (đặt cả ở local .env và trên Vercel → Settings → Env Vars)
# ──────────────────────────────────────────────────────────────────────────

# Kết nối DB lúc chạy (runtime). DÙNG TRANSACTION POOLER — cổng 6543.
# App đã set prepare:false nên tương thích pooler. Đây là biến app đọc đầu tiên.
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Telegram bot cho khung "Tư vấn dược sĩ" (/api/chat) — tin nhắn khách gửi thẳng vào Telegram.
#   TELEGRAM_BOT_TOKEN: lấy từ @BotFather sau khi tạo bot (dạng 123456789:ABC...).
#   TELEGRAM_CHAT_ID:   ID của chat/nhóm nhận tin (nhắn @userinfobot hoặc @getidsbot để lấy).
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmnOPqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ──────────────────────────────────────────────────────────────────────────
# CHỈ DÙNG KHI MIGRATE/SEED TỪ MÁY LOCAL (drizzle-kit push, db:seed)
# KHÔNG cần đặt trên Vercel. DÙNG DIRECT CONNECTION — cổng 5432.
# ──────────────────────────────────────────────────────────────────────────
POSTGRES_URL_NON_POOLING=postgres://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ──────────────────────────────────────────────────────────────────────────
# Do tích hợp Supabase ↔ Vercel tự thêm. App HIỆN KHÔNG dùng (không có supabase-js).
# Có thể bỏ qua, giữ lại cũng không sao.
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
POSTGRES_DATABASE=postgres
POSTGRES_HOST=db.<project-ref>.supabase.co
POSTGRES_PASSWORD=<your-db-password>
POSTGRES_PRISMA_URL=postgres://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_URL=postgres://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require
POSTGRES_USER=postgres
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_JWT_SECRET=<your-jwt-secret>
SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
SUPABASE_SECRET_KEY=<your-secret-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_URL=https://<project-ref>.supabase.co
